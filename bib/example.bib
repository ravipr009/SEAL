@article{sliwowski_conditionnet_2025,
	title = {{ConditionNET}: {Learning} {Preconditions} and {Effects} for {Execution} {Monitoring}},
	volume = {10},
	issn = {2377-3766, 2377-3774},
	shorttitle = {{ConditionNET}},
	url = {http://arxiv.org/abs/2502.01167},
	doi = {10.1109/LRA.2024.3520916},
	abstract = {The introduction of robots into everyday scenarios necessitates algorithms capable of monitoring the execution of tasks. In this paper, we propose ConditionNET, an approach for learning the preconditions and effects of actions in a fully data-driven manner. We develop an efficient vision-language model and introduce additional optimization objectives during training to optimize for consistent feature representations. ConditionNET explicitly models the dependencies between actions, preconditions, and effects, leading to improved performance. We evaluate our model on two robotic datasets, one of which we collected for this paper, containing 406 successful and 138 failed teleoperated demonstrations of a Franka Emika Panda robot performing tasks like pouring and cleaning the counter. We show in our experiments that ConditionNET outperforms all baselines on both anomaly detection and phase prediction tasks. Furthermore, we implement an action monitoring system on a real robot to demonstrate the practical applicability of the learned preconditions and effects. Our results highlight the potential of ConditionNET for enhancing the reliability and adaptability of robots in real-world environments. The data is available on the project website: https://dsliwowski1.github.io/ConditionNET\_page.},
	number = {2},
	urldate = {2025-09-17},
	journal = {IEEE Robot. Autom. Lett.},
	author = {Sliwowski, Daniel and Lee, Dongheui},
	month = feb,
	year = {2025},
	note = {arXiv:2502.01167 [cs]},
	keywords = {Computer Science - Machine Learning, Computer Science - Robotics},
	pages = {1337--1344},
